# Scraper session state & secrets — never commit
.env
# Cursor working state — keep shareable skills
.cursor/*
!.cursor/skills/
!.cursor/skills/**
.auth/
user-data/
*.storage_state.json

# Downloaded invoices / PDFs (keep only the aggregated receipts.txt)
data/*
!data/invoices/
data/invoices/*
!data/invoices/receipts.txt
docs/
/invoices/
/downloads/
*.pdf

# Python
__pycache__/
*.py[cod]
.venv/
venv/
